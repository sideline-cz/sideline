{
  "name": "@sideline/bot",
  "private": true,
  "version": "0.14.2",
  "type": "module",
  "license": "MIT",
  "description": "Discord bot for Sideline",
  "repository": {
    "type": "git",
    "url": "<PLACEHOLDER>",
    "directory": "applications/bot"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "dev": "tsx watch src/run.ts",
    "preview": "node build/esm/run.js",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.40",
    "@sideline/domain": "workspace:^",
    "@sideline/effect-lib": "workspace:^",
    "@sideline/i18n": "workspace:^",
    "@t3-oss/env-core": "^0.13.11",
    "dfx": "1.0.11",
    "discord-api-types": "0.38.47",
    "effect": "4.0.0-beta.40"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
