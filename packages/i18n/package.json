{
  "private": true,
  "name": "@sideline/i18n",
  "version": "0.3.17",
  "type": "module",
  "license": "MIT",
  "description": "Shared translation messages for Sideline",
  "repository": {
    "type": "git",
    "url": "<PLACEHOLDER>",
    "directory": "packages/i18n"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "paraglide-js compile --project ./project.inlang --outdir ./dist --emit-ts-declarations --strategy localStorage cookie preferredLanguage baseLocale && node scripts/pack.js"
  },
  "exports": {
    "./messages": "./dist/messages.js",
    "./runtime": "./dist/runtime.js"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.12.0",
    "typescript": "5.7.2"
  }
}
