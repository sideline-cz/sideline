{
  "private": true,
  "name": "@sideline/template-renderer",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "description": "Pure template rendering utilities for Sideline (no Effect runtime)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maxa-ondrej/sideline.git",
    "directory": "packages/template-renderer"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "devDependencies": {
    "tsc-alias": "*",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
